# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Docket Data Sources ───────────────────────────────────────────────────────
# CourtListener (free, no token required for basic use)
COURTLISTENER_API_TOKEN=

# CourtListener MCP server URL (used by the wrapper server to proxy the official
# hosted MCP server). Defaults to the SSE endpoint below.
COURTLISTENER_MCP_URL=https://mcp.courtlistener.com/sse

# Docket Alarm (commercial, production)
# DOCKET_ALARM_API_KEY=

# ── Microsoft (leave blank for local dev) ─────────────────────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=dockets

# ── Runtime ───────────────────────────────────────────────────────────────────
# "local" uses SQLite + log files. "production" uses SharePoint + Graph API.
ENV=local

# ── Identity ──────────────────────────────────────────────────────────────────
# Attorney identifier stamped on all audit records (conflict checks, opportunity
# logs, status updates). Set to your email or AD UPN on each workstation.
CALLER_ID=
